include ../mixins/sub-menu.pug

header.header
  .container
    .row.align-items-center
      .col-3
        .inner-logo
          a(href="/")
            img(src="/images/logo.svg", alt="Logo")
            
      .col-5
        form(
          action="/search"
          method="GET"
        )
          div(class="form-group d-flex mb-0")
            input(
              type="text"
              placeholder="Nhập từ khóa..."
              class="form-control"
              name="keyword"
              value =keyword
            )
            button(
              type="submit"
              class="btn btn-primary"
            ) Tìm

      .col-4
        .inner-menu
          ul
            li
              a(href="/") Trang chủ
            li(class="sub-menu")
              - const pathProduct = "/products"
              a(href=pathProduct) Sản phẩm
              +sub-menu(layoutProductCategory, pathProduct)
            
            li 
              a(href="/cart")
                span Giỏ hàng (#{miniCart ? miniCart.totalQuantity : 0})
            li 
              a(href="/user/register")
                span Đăng ký
            //- li 
            //-   a(href="/user/login")
            //-     span Đăng nhập
            //- li 
            //-   a(href="/user/forgot-password")
            //-     span Quên mật khẩu
            //- li 
            //-   a(href="/user/reset-password")
            //-     span Đặt lại mật khẩu