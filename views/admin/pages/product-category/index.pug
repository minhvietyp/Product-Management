extends ../../layouts/default.pug
include ../../mixins/filterStatus.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort.pug 
include ../../mixins/table-tree.pug

block main
  if(role.permissions.includes("products-category_view"))

    +alert-success(5000)

    .product-page
      h1.product-page-title Danh mục sản phẩm

      // Bộ lọc và Tìm kiếm
      .card.mb-3.product-filter-card
        .card-header.product-card-header
          | Bộ lọc và Tìm kiếm
        .card-body.product-card-body
          .row.product-toolbar
            .col-6.product-filter-column
              +filter-status(filterStatus)
            .col-6.product-search-column
              +search(keyword)

      // Sắp xếp
      .card.mb-3
        .card-header Sắp xếp
        .card-body
          .row
            .col-4
              +sort(false)

      // Bảng danh mục sản phẩm
      .card.mb-3.product-table-card
        .card-header Danh mục sản phẩm
        .card-body.product-table-card-body
          .row
            .col-8
              // Form thay đổi nhiều danh mục
              +form-change-multi(`${prefixAdmin}/product-category/change-multi?_method=PATCH`)
            .col-4.text-right
              if(role.permissions.includes("products-category_create"))
                a(
                  href=`${prefixAdmin}/product-category/create`
                  class="btn btn-outline-success"
                ) + Thêm mới

        .table-responsive.product-table-responsive
          table.table.table-hover.table-sm.product-table(checkbox-multi)
            thead.product-table-head
              tr.product-table-head-row
                th.product-table-head-cell
                  input(type="checkbox" name="checkall")
                th.product-table-head-cell STT
                th.product-table-head-cell Hình ảnh
                th.product-table-head-cell Tiêu đề
                th.product-table-head-cell Vị trí
                th.product-table-head-cell Trạng thái
                th.product-table-head-cell Hành động

            if(records && records.length > 0)
              +table-tree(records)
            else
              tr
                td(colspan="7" class="text-center") Chưa có danh mục nào được tạo.
            
      +pagination(pagination)

      // Form ẩn đổi trạng thái danh mục
      form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/product-category/change-status`
      )

      // Form ẩn xóa danh mục
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/product-category/delete`
      )

    script(src="/admin/js/product.js")
