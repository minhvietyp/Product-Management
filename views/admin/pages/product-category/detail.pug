extends ../../layouts/default.pug

block main
  if (record.title)
    h1(class="mb-4") #{record.title}

  if (record.parent_id)
    div(class="mb-4") Danh mục cha: <b>#{record.parent_id}</b>

  if (record.thumbnail)
    div(class="mb-4")
      img(
        src=record.thumbnail
        style="width: 100px"
      )

  if (record.status)
    div(class="mb-4")
      span Trạng thái:
      if (record.status === "active")
        span(class="badge badge-success") Hoạt động
      else
        span(class="badge badge-danger") Dừng hoạt động

  if (record.position)
    div(class="mb-4") Vị trí: <b>#{record.position}</b>

  if (record.description)
    div(class="mb-4") !{record.description}

  hr
  if(role.permissions.includes("products-category_edit"))
    a(
      href=`${prefixAdmin}/product-category/edit/${record.id}`
      class="btn btn-warning btn-sm"
    ) Chỉnh sửa

  script(src="/admin/js/product.js")
