mixin search(keyword)
  form(id="form-search" class="product-search-form")
    .input-group.product-search-group
      input(
        type="text"
        placeholder="Nhập từ khóa"
        name="keyword"
        class="form-control product-search-input"
        value=keyword
      )
      button(
        class="btn btn-success product-search-button"
        type="submit"
      ) Tìm kiếm